rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function normalizedEmail(email) {
      return email.lower();
    }

    function isTutorEmail(email) {
      return exists(
        /databases/$(database)/documents/tutor_whitelist/$(normalizedEmail(email))
      );
    }

    function roleMatchesWhitelist(role, email) {
      return role == 'tutor'
        ? isTutorEmail(email)
        : !isTutorEmail(email);
    }

    function isValidUserWrite(userId) {
      let data = request.resource.data;
      return data.uid == userId
        && data.email == request.auth.token.email
        && data.role in ['student', 'tutor']
        && roleMatchesWhitelist(data.role, data.email);
    }

    function isTutor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tutor';
    }

    // Tutor emails — maintain via Firebase Console or Admin SDK only.
    match /tutor_whitelist/{emailId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);

      // Tutors loading the student roster (query must filter role == 'student').
      allow read: if isTutor() && resource.data.role == 'student';

      allow create: if isOwner(userId) && isValidUserWrite(userId);

      allow update: if isOwner(userId)
        && isValidUserWrite(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt;

      match /bookmarks/{questionId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /assignments/{assignmentId} {
      // Split read rules (no OR) so list queries work with security constraints.
      allow read: if isSignedIn()
        && resource.data.assignedToStudentUid == request.auth.uid;

      allow read: if isSignedIn()
        && resource.data.tutorUid == request.auth.uid;

      allow create: if isTutor()
        && request.resource.data.tutorUid == request.auth.uid
        && request.resource.data.assignedToStudentUid is string
        && request.resource.data.questionIds is list
        && request.resource.data.questionIds.size() > 0
        && request.resource.data.status == 'todo'
        && request.resource.data.dueAt is timestamp;

      // Tutor links assignment to a workspace card after create.
      allow update: if isTutor()
        && resource.data.tutorUid == request.auth.uid
        && request.resource.data.tutorUid == resource.data.tutorUid
        && request.resource.data.assignedToStudentUid == resource.data.assignedToStudentUid
        && request.resource.data.questionIds == resource.data.questionIds
        && request.resource.data.status == resource.data.status
        && request.resource.data.dueAt == resource.data.dueAt
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['workspaceCardId']);

      allow update: if isSignedIn()
        && resource.data.assignedToStudentUid == request.auth.uid
        && resource.data.status == 'todo'
        && request.resource.data.status == 'completed'
        && request.resource.data.tutorUid == resource.data.tutorUid
        && request.resource.data.assignedToStudentUid == resource.data.assignedToStudentUid
        && request.resource.data.questionIds == resource.data.questionIds
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'completedAt']);
    }

    function workspaceBoardIdMatchesStudent(boardId) {
      return isSignedIn() && boardId == request.auth.uid;
    }

    function canAccessWorkspaceBoard(boardId) {
      return isTutor()
        || workspaceBoardIdMatchesStudent(boardId);
    }

    function workspaceBoardNotDeleted() {
      return resource == null
        || !('deletedAt' in resource.data)
        || resource.data.deletedAt == null;
    }

    match /workspace_boards/{boardId} {
      // Tutors: list all boards, or get a board that does not exist yet (resource == null).
      allow read: if isTutor() && workspaceBoardNotDeleted();

      // Students: only their own existing board.
      allow read: if resource != null
        && workspaceBoardIdMatchesStudent(boardId)
        && resource.data.studentUid == request.auth.uid
        && workspaceBoardNotDeleted();

      allow create: if isTutor()
        && request.resource.data.studentUid == boardId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.studentName is string
        && request.resource.data.studentEmail is string
        && !('deletedAt' in request.resource.data);

      allow update: if isTutor()
        && request.resource.data.studentUid == resource.data.studentUid
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;

      match /lists/{listId} {
        allow read: if canAccessWorkspaceBoard(boardId);
        allow create, update: if isTutor();
        allow delete: if false;
      }

      match /cards/{cardId} {
        allow read: if canAccessWorkspaceBoard(boardId);
        allow create, update: if isTutor();
        allow delete: if false;

        match /attachments/{attachmentId} {
          allow read: if canAccessWorkspaceBoard(boardId)
            && (!('deletedAt' in resource.data) || resource.data.deletedAt == null);

          allow create: if isTutor()
            && request.resource.data.uploadedByUid == request.auth.uid
            && request.resource.data.fileName is string
            && !('deletedAt' in request.resource.data)
            && (!('dueAt' in request.resource.data) || request.resource.data.dueAt is timestamp)
            && (
              (request.resource.data.kind == 'link'
                && request.resource.data.externalUrl is string
                && request.resource.data.externalUrl.size() > 0)
              || (request.resource.data.kind == 'file'
                && request.resource.data.storagePath is string)
            );

          allow update: if isTutor()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedAt']);

          allow delete: if false;

          match /submissions/{submissionId} {
            allow read: if canAccessWorkspaceBoard(boardId);

            allow create: if workspaceBoardIdMatchesStudent(boardId)
              && request.resource.data.submittedByUid == request.auth.uid
              && request.resource.data.submissionUrl is string
              && request.resource.data.submissionUrl.size() > 0
              && request.resource.data.submittedByName is string;

            allow update, delete: if false;
          }
        }

        match /comments/{commentId} {
          allow read: if canAccessWorkspaceBoard(boardId)
            && (!('deletedAt' in resource.data) || resource.data.deletedAt == null);

          allow create: if canAccessWorkspaceBoard(boardId)
            && request.resource.data.authorUid == request.auth.uid
            && request.resource.data.body is string
            && request.resource.data.body.size() > 0
            && !('deletedAt' in request.resource.data);

          allow update: if isTutor()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedAt']);

          allow delete: if false;
        }

        match /activity/{activityId} {
          allow read: if canAccessWorkspaceBoard(boardId);
          allow create: if canAccessWorkspaceBoard(boardId)
            && request.resource.data.actorUid == request.auth.uid
            && request.resource.data.message is string;
          allow update, delete: if false;
        }
      }
    }

    match /practice_sessions/{sessionId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.sessionType in ['assignment', 'self', 'tutor-preview'];

      // Students: own sessions only (query must use userId == auth.uid).
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      // Tutors: assignment sessions for their class (query must use tutorUid + sessionType).
      allow read: if isSignedIn()
        && resource.data.tutorUid == request.auth.uid
        && resource.data.sessionType == 'assignment'
        && isTutor();
    }
  }
}
