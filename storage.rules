rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTutor() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'tutor';
    }

    function canAccessWorkspaceBoard(boardId) {
      let board = firestore.get(/databases/(default)/documents/workspace_boards/$(boardId));
      return isSignedIn()
        && board != null
        && (board.data.studentUid == request.auth.uid || isTutor());
    }

    match /workspace/{boardId}/cards/{cardId}/{fileName} {
      allow read: if canAccessWorkspaceBoard(boardId);

      allow write: if isTutor()
        && canAccessWorkspaceBoard(boardId)
        && request.resource.size < 25 * 1024 * 1024;
    }
  }
}
